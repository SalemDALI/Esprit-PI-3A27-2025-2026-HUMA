<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" alignment="CENTER"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.LoginController"
      stylesheets="@../style.css"
      styleClass="login-root">

    <Label text="LOGIN" styleClass="title"/>

    <TextField fx:id="emailField" promptText="Email" maxWidth="320"/>
    <PasswordField fx:id="passwordField" promptText="Mot de passe" maxWidth="320"/>
    <Button text="Login with Face ID" onAction="#loginWithFace"/>
    <Button text="Se connecter" styleClass="btn btn-primary" onAction="#login"/>
    <Button text="Sign up" styleClass="btn" onAction="#openSignup"/>
    <Hyperlink text="Mot de passe oublié ?"
               onAction="#showForgotPassword"
               styleClass="link"/>

    <Label fx:id="messageLabel" textFill="#ff6b6b"/>

</VBox>
