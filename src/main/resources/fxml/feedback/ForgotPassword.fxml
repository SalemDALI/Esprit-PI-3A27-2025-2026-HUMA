<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.recrutement.ForgotPasswordController"
      spacing="15" alignment="CENTER" style="-fx-padding: 20;">

    <Label text="Mot de passe oublié ?" style="-fx-font-size:18px; -fx-font-weight:bold;"/>
    <Label text="Entrez votre email pour recevoir un code OTP" wrapText="true"/>

    <TextField fx:id="tfEmail" promptText="Email" maxWidth="320"/>
    <HBox spacing="10" alignment="CENTER">
        <Button text="Envoyer le code par email" onAction="#sendOtpByEmail"/>
        <Button fx:id="btnSendSms" text="Envoyer le code par SMS" onAction="#sendOtpBySms"/>
    </HBox>
    <TextField fx:id="tfPhone" promptText="Téléphone (SMS, ex: +33612345678)" maxWidth="320"/>

    <Label text="Code OTP reçu (email ou SMS)" wrapText="true"/>
    <TextField fx:id="tfOtp" promptText="Code à 6 chiffres" maxWidth="320"/>
    <Button text="Vérifier le code" onAction="#verifyOtp"/>

    <VBox fx:id="passwordBox" spacing="10" alignment="CENTER" visible="false" managed="false">
        <Label text="Nouveau mot de passe" wrapText="true"/>
        <PasswordField fx:id="pfNewPassword" promptText="Nouveau mot de passe" maxWidth="320"/>
        <PasswordField fx:id="pfConfirmPassword" promptText="Confirmer le mot de passe" maxWidth="320"/>
        <Button text="Changer le mot de passe" onAction="#doResetPassword"/>
    </VBox>

    <Label fx:id="lblMessage" style="-fx-text-fill:red;" wrapText="true" maxWidth="320"/>

</VBox>
