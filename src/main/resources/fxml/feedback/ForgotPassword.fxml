<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.recrutement.ForgotPasswordController"
      spacing="15" alignment="CENTER" padding="20">

    <Label text="Mot de passe oublié ?" style="-fx-font-size:18px; -fx-font-weight:bold;"/>
    <Label text="Entrez votre email pour recevoir un lien de réinitialisation" wrapText="true"/>

    <TextField fx:id="tfEmail" promptText="Email"/>
    <Button text="Envoyer" onAction="#sendResetEmail"/>
    <Label fx:id="lblMessage" style="-fx-text-fill:red;"/>

</VBox>