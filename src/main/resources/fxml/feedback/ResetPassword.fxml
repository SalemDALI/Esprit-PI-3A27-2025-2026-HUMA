<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.recrutement.ResetPasswordController"
      spacing="15" alignment="CENTER" padding="20">

    <Label text="Réinitialiser le mot de passe" style="-fx-font-size:18px; -fx-font-weight:bold;"/>
    <PasswordField fx:id="pfPassword" promptText="Nouveau mot de passe"/>
    <PasswordField fx:id="pfConfirmPassword" promptText="Confirmer le mot de passe"/>
    <Button text="Réinitialiser" onAction="#resetPassword"/>
    <Label fx:id="lblMessage" style="-fx-text-fill:red;"/>
</VBox>