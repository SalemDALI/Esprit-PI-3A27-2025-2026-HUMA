<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="12" alignment="CENTER"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.SignupController"
      stylesheets="@style.css"
      styleClass="login-root">

    <Label text="SIGN UP" styleClass="title"/>

    <TextField fx:id="nomField" promptText="Nom" maxWidth="320"/>
    <TextField fx:id="prenomField" promptText="Prenom" maxWidth="320"/>
    <TextField fx:id="emailField" promptText="Email" maxWidth="320"/>
    <PasswordField fx:id="passwordField" promptText="Mot de passe" maxWidth="320"/>
    <PasswordField fx:id="confirmPasswordField" promptText="Confirmer mot de passe" maxWidth="320"/>

    <Button text="Creer un compte" styleClass="btn btn-primary" onAction="#signup"/>
    <Button text="Retour Login" styleClass="btn" onAction="#backToLogin"/>

    <Label fx:id="messageLabel" textFill="#ff6b6b"/>
</VBox>
