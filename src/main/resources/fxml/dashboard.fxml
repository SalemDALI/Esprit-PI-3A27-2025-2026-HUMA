<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.DashboardController"
            stylesheets="@style.css"
            styleClass="app-root">

    <left>
        <VBox spacing="10" styleClass="sidebar dashboard-sidebar" prefWidth="220">
            <HBox spacing="8" styleClass="brand-row">
                <ImageView fitHeight="56.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@../images/huma.png"/>
                    </image>
                </ImageView>
            </HBox>

            <Button text="Tableau de bord" styleClass="nav-button" onAction="#openDashboard">
                <graphic>
                    <ImageView fitHeight="22.0" fitWidth="22.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                            <Image url="@../images/dashboard.png"/>
                        </image>
                    </ImageView>
                </graphic>
            </Button>
            <Button text="Recrutement" styleClass="nav-button nav-active" onAction="#openRecrutement">
                <graphic>
                    <ImageView fitHeight="22.0" fitWidth="22.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                            <Image url="@../images/recrutement.png"/>
                        </image>
                    </ImageView>
                </graphic>
            </Button>
            <Button text="Congés" styleClass="nav-button" onAction="#openConges">
                <graphic>
                    <ImageView fitHeight="22.0" fitWidth="22.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                            <Image url="@../images/conge.png"/>
                        </image>
                    </ImageView>
                </graphic>
            </Button>
            <Button text="Absences" styleClass="nav-button" onAction="#openAbsences">
                <graphic>
                    <ImageView fitHeight="22.0" fitWidth="22.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                            <Image url="@../images/absences.png"/>
                        </image>
                    </ImageView>
                </graphic>
            </Button>
            <Button text="Communication" styleClass="nav-button" onAction="#openCommunication">
                <graphic>
                    <ImageView fitHeight="22.0" fitWidth="22.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                            <Image url="@../images/communication.png"/>
                        </image>
                    </ImageView>
                </graphic>
            </Button>
            <Button text="FeedBack" styleClass="nav-button" onAction="#openFeedback">
                <graphic>
                    <ImageView fitHeight="22.0" fitWidth="22.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                            <Image url="@../images/feedback.png"/>
                        </image>
                    </ImageView>
                </graphic>
            </Button>
            <Button text="Paramètres" styleClass="nav-button" onAction="#openParametres">
                <graphic>
                    <ImageView fitHeight="22.0" fitWidth="22.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                            <Image url="@../images/parametre.png"/>
                        </image>
                    </ImageView>
                </graphic>
            </Button>
            <Region VBox.vgrow="ALWAYS"/>
            <Button text="Logout" styleClass="nav-button" onAction="#logout"/>
        </VBox>
    </left>


    <center>
        <VBox spacing="16" styleClass="main-content">
            <HBox styleClass="top-toolbar">
                <Label text="Tableau de bord" styleClass="dashboard-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <HBox spacing="8" styleClass="tool-group">
                    <TextField promptText="Search..." styleClass="search-input"/>
                    <Button text="⌂" styleClass="tool-btn"/>
                    <Button text="＋" styleClass="tool-btn tool-btn-accent"/>
                    <Button text="👤" styleClass="tool-btn"/>
                </HBox>
            </HBox>

            <HBox spacing="12" styleClass="cards-row">
                <VBox styleClass="metric-card metric-green">
                    <Label fx:id="lblCardPostes" text="0" styleClass="card-number"/>
                    <Label text="Postes ouverts" styleClass="card-subtitle"/>
                </VBox>
                <VBox styleClass="metric-card metric-red">
                    <Label fx:id="lblCardDemandes" text="0" styleClass="card-number"/>
                    <Label text="Demandes en attente" styleClass="card-subtitle"/>
                </VBox>
                <VBox styleClass="metric-card metric-orange">
                    <Label fx:id="lblCardEmployes" text="0" styleClass="card-number"/>
                    <Label text="Employés" styleClass="card-subtitle"/>
                </VBox>
            </HBox>

            <Label fx:id="lblPageMessage" text="" styleClass="page-message"/>
        </VBox>
    </center>

</BorderPane>
