<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="app-root" stylesheets="@style.css" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25" fx:controller="controller.DashboardController">

    <left>
        <VBox prefWidth="220" spacing="10" styleClass="sidebar dashboard-sidebar">
            <HBox spacing="8" styleClass="brand-row">
                <ImageView fitHeight="78.0" fitWidth="240.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@../images/huma.png" />
                    </image>
                </ImageView>
            </HBox>

            <Button onAction="#openDashboard" prefWidth="233.0" styleClass="nav-button" text="Tableau de bord">
                <graphic>
                    <ImageView fitHeight="22.0" fitWidth="22.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                            <Image url="@../images/dashboard.png" />
                        </image>
                    </ImageView>
                </graphic>
            </Button>
            <Button onAction="#openRecrutement" prefWidth="275.0" styleClass="nav-button" text="Recrutement">
                <graphic>
                    <ImageView fitHeight="22.0" fitWidth="22.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                            <Image url="@../images/recrutement.png" />
                        </image>
                    </ImageView>
                </graphic>
            </Button>
            <Button onAction="#openConges" prefHeight="40.0" prefWidth="285.0" styleClass="nav-button nav-active" text="Congés">
                <graphic>
                    <ImageView fitHeight="22.0" fitWidth="22.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                            <Image url="@../images/conge.png" />
                        </image>
                    </ImageView>
                </graphic>
            </Button>
            <Button onAction="#openAbsences" prefWidth="229.0" styleClass="nav-button" text="Absences">
                <graphic>
                    <ImageView fitHeight="22.0" fitWidth="22.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                            <Image url="@../images/absences.png" />
                        </image>
                    </ImageView>
                </graphic>
            </Button>
            <Button onAction="#openCommunication" prefWidth="266.0" styleClass="nav-button" text="Communication">
                <graphic>
                    <ImageView fitHeight="22.0" fitWidth="22.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                            <Image url="@../images/communication.png" />
                        </image>
                    </ImageView>
                </graphic>
            </Button>
            <Button onAction="#openFeedback" styleClass="nav-button" text="FeedBack">
                <graphic>
                    <ImageView fitHeight="22.0" fitWidth="22.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                            <Image url="@../images/feedback.png" />
                        </image>
                    </ImageView>
                </graphic>
            </Button>
            <Button onAction="#openParametres" prefWidth="325.0" styleClass="nav-button" text="Paramètres">
                <graphic>
                    <ImageView fitHeight="22.0" fitWidth="22.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                            <Image url="@../images/parametre.png" />
                        </image>
                    </ImageView>
                </graphic>
            </Button>
            <Region VBox.vgrow="ALWAYS" />
            <Button onAction="#logout" prefWidth="288.0" styleClass="nav-button" text="Logout" />
        </VBox>
    </left>

    <center>
        <VBox spacing="16" styleClass="main-content">
            <HBox styleClass="top-toolbar" />

            <StackPane prefHeight="1107.0" prefWidth="152.0" styleClass="workspace-panel" VBox.vgrow="ALWAYS">
                <Label styleClass="page-message" text="Page congés (vide)." />
            </StackPane>
        </VBox>
    </center>

</BorderPane>
