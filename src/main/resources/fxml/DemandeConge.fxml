<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>
<?import javafx.scene.control.Button?>
<VBox spacing="10" alignment="CENTER" xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.DemandeCongeController">

    <DatePicker fx:id="dateDebut"/>
    <DatePicker fx:id="dateFin"/>

    <ComboBox fx:id="typeAbsence">
        <items>
            <FXCollections fx:factory="observableArrayList">
                <String fx:value="CONGE"/>
                <String fx:value="MALADIE"/>
            </FXCollections>
        </items>
    </ComboBox>

    <Button text="Demander">
        <onAction>#handleDemande</onAction>
    </Button>
</VBox>
