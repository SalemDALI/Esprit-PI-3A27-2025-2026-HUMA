<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.DashboardController"
            stylesheets="@style.css"
            styleClass="app-root">

    <left>
        <VBox spacing="10" styleClass="sidebar dashboard-sidebar" prefWidth="220">
            <HBox spacing="8" styleClass="brand-row">
                <ImageView fitHeight="78.0" fitWidth="240.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@../images/huma.png"/>
                    </image>
                </ImageView>
            </HBox>

            <Button text="Tableau de bord" styleClass="nav-button" onAction="#openDashboard">
                <graphic>
                    <ImageView fitHeight="22.0" fitWidth="22.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                            <Image url="@../images/dashboard.png"/>
                        </image>
                    </ImageView>
                </graphic>
            </Button>
            <Button text="Recrutement" styleClass="nav-button" onAction="#openRecrutement">
                <graphic>
                    <ImageView fitHeight="22.0" fitWidth="22.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                            <Image url="@../images/recrutement.png"/>
                        </image>
                    </ImageView>
                </graphic>
            </Button>
            <Button text="Congés" styleClass="nav-button" onAction="#openConges">
                <graphic>
                    <ImageView fitHeight="22.0" fitWidth="22.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                            <Image url="@../images/conge.png"/>
                        </image>
                    </ImageView>
                </graphic>
            </Button>
            <Button text="Absences" styleClass="nav-button" onAction="#openAbsences">
                <graphic>
                    <ImageView fitHeight="22.0" fitWidth="22.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                            <Image url="@../images/absences.png"/>
                        </image>
                    </ImageView>
                </graphic>
            </Button>
            <Button text="Communication" styleClass="nav-button nav-active" onAction="#openCommunication">
                <graphic>
                    <ImageView fitHeight="22.0" fitWidth="22.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                            <Image url="@../images/communication.png"/>
                        </image>
                    </ImageView>
                </graphic>
            </Button>
            <Button text="FeedBack" styleClass="nav-button" onAction="#openFeedback">
                <graphic>
                    <ImageView fitHeight="22.0" fitWidth="22.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                            <Image url="@../images/feedback.png"/>
                        </image>
                    </ImageView>
                </graphic>
            </Button>
            <Button text="Paramètres" styleClass="nav-button" onAction="#openParametres">
                <graphic>
                    <ImageView fitHeight="22.0" fitWidth="22.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                            <Image url="@../images/parametre.png"/>
                        </image>
                    </ImageView>
                </graphic>
            </Button>
            <Region VBox.vgrow="ALWAYS"/>
            <Button text="Logout" styleClass="nav-button" onAction="#logout"/>
        </VBox>
    </left>

    <center>
        <VBox spacing="16" styleClass="main-content">
            <HBox styleClass="top-toolbar">
                <Label text="Communication" styleClass="dashboard-title"/>
            </HBox>

            <StackPane styleClass="workspace-panel" VBox.vgrow="ALWAYS">
                <Label text="Page communication (vide)." styleClass="page-message"/>
            </StackPane>
        </VBox>
    </center>

</BorderPane>
