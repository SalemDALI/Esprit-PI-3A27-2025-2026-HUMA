<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.ManagerAbsenceController"
            stylesheets="@style.css"
            styleClass="app-root">

    <top>
        <HBox styleClass="sidebar topbar" spacing="10">
            <Label text="Espace Manager - Absences" styleClass="logo"/>
            <Pane HBox.hgrow="ALWAYS"/>
            <Button text="Logout" styleClass="nav-button" onAction="#logout"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="12" styleClass="content">
            <Label text="Demandes de l'equipe" styleClass="title"/>
            <Label fx:id="lblActionMessage" styleClass="page-message" text=""/>

            <TableView fx:id="tableAbsences" prefHeight="360" styleClass="modern-table">
                <columns>
                    <TableColumn fx:id="colEmploye" text="Employe" prefWidth="110"/>
                    <TableColumn fx:id="colType" text="Type" prefWidth="150"/>
                    <TableColumn fx:id="colDebut" text="Debut" prefWidth="140"/>
                    <TableColumn fx:id="colFin" text="Fin" prefWidth="140"/>
                    <TableColumn fx:id="colStatut" text="Statut" prefWidth="140"/>
                </columns>
            </TableView>

            <HBox spacing="10" styleClass="action-row">
                <Button text="Accepter" styleClass="btn btn-primary" onAction="#accepter"/>
                <Button text="Refuser" styleClass="btn btn-danger" onAction="#refuser"/>
                <Button text="Actualiser" styleClass="btn" onAction="#refresh"/>
            </HBox>
        </VBox>
    </center>

</BorderPane>
